# AudioQuack Bot Environment Variables
# Copy this file to .env and fill in your values

# Discord Bot Token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord OAuth2 Client Secret (required for dashboard auth)
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Dashboard session secret (optional, will use default if not set)
DASHBOARD_SECRET=your_super_secret_dashboard_key

# OAuth2 Callback URL (optional, defaults to production URL)
CALLBACK_URL=https://audioquack.bot.nu/auth/discord/callback

# Server port (optional, defaults to 3000)
PORT=3000