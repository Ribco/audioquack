# AudioQuack Bot Environment Variables
# Copy this file to .env and fill in your values

# Discord Bot Token (required)
DISCORD_TOKEN=your-discord-bot-token

# Discord OAuth2 Client ID (optional, defaults to bundled AudioQuack application)
DISCORD_CLIENT_ID=your-discord-client-id

# Discord OAuth2 Client Secret (required for dashboard auth)
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Spotify Client ID (optional, for Spotify integration)
SPOTIFY_CLIENT_ID=your-spotify-client-id

# Spotify Client Secret (optional, for Spotify integration)
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Enable Spotify integration (set to 'true' to enable)
ENABLE_SPOTIFY=false

# Dashboard session secret (optional, will use default if not set)
DASHBOARD_SECRET=super-secret-key-quack-quackify

# OAuth2 Callback URL (optional, defaults to local development URL)
CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Server port (optional, defaults to 3000)
PORT=3000

# Maximum queue size (optional, defaults to 100)
MAX_QUEUE_SIZE=100

# Default volume (optional, defaults to 100)
DEFAULT_VOLUME=100

# Maximum volume (optional, defaults to 200)
MAX_VOLUME=200

# Leave timeout in ms (optional, defaults to 30000)
LEAVE_TIMEOUT=30000

# Search result limit (optional, defaults to 5)
SEARCH_LIMIT=5

# Enable Spotify integration (optional, defaults to false)
ENABLE_SPOTIFY=true

# Enable autoplay (optional, defaults to true)
ENABLE_AUTOPLAY=true

# Log level (optional, defaults to info)
LOG_LEVEL=info
